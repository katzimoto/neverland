# Neverland air-gapped Compose environment template.
# Copy to `.env`, replace every `change-me-*` placeholder, and keep real secrets
# outside source control and outside release artifacts.

APP_ENV=prod
APP_VERSION=airgap
BUILD_COMMIT=unknown

# First-party image tags loaded from images/neverland-images.tar.
NEVERLAND_BACKEND_IMAGE=neverland/backend:airgap
NEVERLAND_FRONTEND_IMAGE=neverland/frontend:airgap
# LibreTranslate image with pre-installed language packs bundled for air-gapped operation.
NEVERLAND_LIBRETRANSLATE_IMAGE=neverland/libretranslate:airgap

# Core services
POSTGRES_DB=app
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-postgres-password
POSTGRES_URL=postgresql+psycopg://postgres:change-me-postgres-password@postgres:5432/app
KAFKA_BROKER=kafka:9092
ELASTIC_URL=http://elasticsearch:9200
QDRANT_URL=http://qdrant:6333
FILES_ROOT=/data
JWT_SECRET=change-me-jwt-secret
CORS_ORIGINS=http://localhost:8080

# Translation and local intelligence services included in the offline image bundle.
LIBRETRANSLATE_URL=http://libretranslate:5000
# Supported translation language codes bundled in the air-gapped LibreTranslate image.
# Unsupported languages are indexed and searchable as original text but not translated.
# Chinese support in this RC means Chinese Simplified (zh) only.
SUPPORTED_TRANSLATION_SOURCE_LANGUAGES=en,he,zh,ko,th,ar,fr,ru,es
SUPPORTED_TRANSLATION_TARGET_LANGUAGES=en,he,zh,ko,th,ar,fr,ru,es
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=mistral

# Auth: use local, ldap, or both. LDAP placeholders are ignored when AUTH_PROVIDER=local.
AUTH_PROVIDER=local
LDAP_URL=ldap://domain-controller:389
LDAP_BASE_DN=DC=company,DC=local
LDAP_BIND_USER=cn=svc-search,DC=company,DC=local
LDAP_BIND_PASSWORD=change-me-ldap-bind-password

# Folder connector host mount. Create this host path before starting Compose and
# use the container path when adding the folder source in Admin Sources.
NEVERLAND_FOLDER_SOURCE_HOST_PATH=./operator-data/folder-source
NEVERLAND_FOLDER_SOURCE_CONTAINER_PATH=/sources/folder

# Feature flags and runtime defaults.
FEATURE_DOCUMENT_COMMENTS=true
FEATURE_RAG_QA=true
FEATURE_SUMMARIZATION=true
FEATURE_ENTITY_EXTRACTION=true
FEATURE_ANNOTATIONS=true
FEATURE_SUBSCRIPTIONS=true
FEATURE_EXPERTISE_MAP=true
FEATURE_RELATED_DOCS=true
FEATURE_AUTO_TAGGING=true
AUTO_ENRICH_THRESHOLD=5
INGEST_MODE=hybrid

# Published host ports. In the air-gapped compose file, the direct API port and
# infrastructure ports are bound to 127.0.0.1; expose them outside the host only
# with deliberate firewall and reverse-proxy controls.
API_PORT=8000
FRONTEND_PORT=8080
POSTGRES_PORT=5432
KAFKA_PORT=9092
ELASTICSEARCH_PORT=9200
QDRANT_PORT=6333
LIBRETRANSLATE_PORT=5000
OLLAMA_PORT=11434
