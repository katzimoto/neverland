      "id": 1,
      "type": "timeseries",
      "title": "HTTP request rate",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "neverland-prometheus"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "neverland-prometheus"
          },
          "expr": "sum by (method, route, status_class) (rate(neverland_http_requests_total[5m]))",
          "legendFormat": "{{method}} {{route}} {{status_class}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "single",
          "sort": "none"
        }
      }
    },
