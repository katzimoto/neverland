# Neverland production Compose environment template.
# Copy to `.env`, replace every `change-me-*` placeholder before storing real data,
# and keep this file free of real passwords, tokens, and secrets.

# Required: runtime profile for the API containers; production Compose should use `prod`.
APP_ENV=prod
# Optional build metadata exposed as Prometheus labels; set during image/build promotion when available.
APP_VERSION=0.1.0
BUILD_COMMIT=unknown

# Core services
# Required: PostgreSQL database name created by the postgres container.
POSTGRES_DB=app
# Required: PostgreSQL user created by the postgres container.
POSTGRES_USER=postgres
# Required secret: PostgreSQL password; replace before first production use.
POSTGRES_PASSWORD=change-me-postgres-password
# Required: SQLAlchemy database URL; keep the user, password, host, port, and DB in sync with POSTGRES_*.
POSTGRES_URL=postgresql+psycopg://postgres:change-me-postgres-password@postgres:5432/app
# Required: Kafka/Redpanda broker URL used by event publishers.
KAFKA_BROKER=kafka:9092
# Required: Elasticsearch HTTP URL used for full-text indexing and search.
ELASTIC_URL=http://elasticsearch:9200
# Required: Qdrant HTTP URL used for vector storage and semantic search.
QDRANT_URL=http://qdrant:6333
# Required: in-container file storage root mounted from the files_data volume.
FILES_ROOT=/data
# Required secret: JWT signing key; replace with a long random value before first production use.
JWT_SECRET=change-me-jwt-secret
# Required: comma-separated browser origins allowed to call the API; do not use `*` in production.
CORS_ORIGINS=http://localhost:8080

# Translation
# Required: LibreTranslate HTTP URL used for language detection and translation.
LIBRETRANSLATE_URL=http://libretranslate:5000
# Optional: comma-separated list of language codes available for translation source/target.
# These codes are served by the bundled LibreTranslate image. Unsupported languages are
# indexed and searchable as original text but not offered for translation.
# zt (Traditional Chinese) is included if present in the Argos Translate package index at
# build time; see docs/operations/air-gapped-deployment.md for the supported language matrix.
SUPPORTED_TRANSLATION_SOURCE_LANGUAGES=en,he,zh,zt,ko,th,ar,fr,ru,es
SUPPORTED_TRANSLATION_TARGET_LANGUAGES=en,he,zh,zt,ko,th,ar,fr,ru,es

# Local LLM
# Required when intelligence features are enabled: Ollama HTTP URL.
OLLAMA_URL=http://ollama:11434
# Required when intelligence features are enabled: Ollama model name to use for summaries, tags, and Q&A.
OLLAMA_MODEL=mistral

# Auth
# Required: authentication backend; use `local`, `ldap`, or `both`.
AUTH_PROVIDER=local
# Required only when AUTH_PROVIDER is `ldap` or `both`: LDAP server URL.
LDAP_URL=ldap://domain-controller:389
# Required only when AUTH_PROVIDER is `ldap` or `both`: LDAP search base DN.
LDAP_BASE_DN=DC=company,DC=local
# Required only when AUTH_PROVIDER is `ldap` or `both`: LDAP bind user DN.
LDAP_BIND_USER=cn=svc-search,DC=company,DC=local
# Required secret only when AUTH_PROVIDER is `ldap` or `both`: LDAP bind user password.
LDAP_BIND_PASSWORD=change-me-ldap-bind-password

# Feature flags and runtime defaults. Database-backed system_config values can override these at runtime.
# Optional feature flag: enable document comment APIs and UI behavior.
FEATURE_DOCUMENT_COMMENTS=true
# Optional feature flag: enable retrieval-augmented Q&A features.
FEATURE_RAG_QA=true
# Optional feature flag: enable document summarization.
FEATURE_SUMMARIZATION=true
# Optional feature flag: enable entity extraction.
FEATURE_ENTITY_EXTRACTION=true
# Optional feature flag: enable document annotations.
FEATURE_ANNOTATIONS=true
# Optional feature flag: enable subscription and notification discovery features.
FEATURE_SUBSCRIPTIONS=true
# Optional feature flag: enable expertise map features.
FEATURE_EXPERTISE_MAP=true
# Optional feature flag: enable related-document discovery.
FEATURE_RELATED_DOCS=true
# Optional feature flag: enable automatic tagging.
FEATURE_AUTO_TAGGING=true
# Optional local-development default: document view count that triggers automatic translation enrichment.
AUTO_ENRICH_THRESHOLD=5
# Optional local-development default: ingestion mode, one of `hybrid`, `watch`, or `poll`.
INGEST_MODE=hybrid

# Published local ports. Change these only when host ports conflict.
# Optional local port: API HTTP endpoint published from the api container.
API_PORT=8000
# Optional local port: frontend Nginx endpoint published from the frontend container.
FRONTEND_PORT=8080
# Optional local port: PostgreSQL endpoint published for local maintenance tools.
POSTGRES_PORT=5432
# Optional local port: Kafka/Redpanda endpoint published for local maintenance tools.
KAFKA_PORT=9092
# Optional local port: Elasticsearch endpoint published for local maintenance tools.
ELASTICSEARCH_PORT=9200
# Optional local port: Qdrant endpoint published for local maintenance tools.
QDRANT_PORT=6333
# Optional local port: LibreTranslate endpoint published for local maintenance tools.
LIBRETRANSLATE_PORT=5000
# Optional local port: Ollama endpoint published for local maintenance tools.
OLLAMA_PORT=11434
